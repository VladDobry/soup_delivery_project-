# Copy this file to .env on the server and fill in real values.
# Do not commit real secrets.

DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=example.ru,www.example.ru
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.ru,https://www.example.ru

# Keep this False until Nginx has a valid HTTPS certificate.
# Set it to True after certbot succeeds.
DJANGO_SECURE_SSL_REDIRECT=False

# Keep HSTS disabled for the first launch. Enable later after HTTPS is stable.
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False

# Optional. Leave empty to use local SQLite.
# Example for PostgreSQL:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=
